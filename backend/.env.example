# --- BiteSense backend configuration ---
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Server
BITESENSE_ADDR=:8080
BITESENSE_DATA_DIR=./data
BITESENSE_UPLOAD_DIR=./data/uploads

# Database (SQLite file path; created on first start)
BITESENSE_DB_PATH=./data/bitesense.db

# Auth
# 32+ byte random string; rotate to invalidate all sessions.
BITESENSE_JWT_SECRET=change-me-to-32-or-more-random-bytes
BITESENSE_JWT_ACCESS_TTL=15m
BITESENSE_JWT_REFRESH_TTL=720h

# Vision providers
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
BITESENSE_VISION_FALLBACK_THRESHOLD=0.6

# Open Food Facts (no key required, courtesy User-Agent only)
BITESENSE_OFF_USER_AGENT=BiteSense/0.1 (+https://github.com/marvinf95/bitesense)

# CORS
BITESENSE_CORS_ALLOWED_ORIGINS=http://localhost:*,https://*.ts.net

# Logging
BITESENSE_LOG_LEVEL=info
BITESENSE_LOG_FORMAT=json
